{
  fizzbuzz: (limit: :natural_number.type) => {
    fizzbuzz_internal: (state: { current: :natural_number.type, output: :object.type }) => @if {
      :state.current > :limit
      then: :state.output
      else: :fizzbuzz_internal({
        output: :state.output object.overlay :object.from_property(:state.current)(@if {
          (:state.current % 3 integer.equals 0) && (:state.current % 5 integer.equals 0)
          then: FizzBuzz
          else: @if {
            (:state.current % 3 integer.equals 0)
            then: Fizz
            else: @if {
              :state.current % 5 integer.equals 0
              then: Buzz
              else: :state.current
            }
          }
        })
        current: (:state.current + 1) assume :natural_number.type
      })
    }
    internal_return: :fizzbuzz_internal({ current: 1, output: {} })
  }.internal_return

  input: @runtime { context =>
    // read --input from command-line arguments
    :context.arguments.lookup(input)
  }

  output: :input
    option.flat_map :natural_number.from
    match {
      none: _ => "missing or invalid --input argument (must be a natural number)"
      some: :fizzbuzz
    }
}.output
