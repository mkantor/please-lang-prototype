/**
  * Looks up the value of the given environment variable.
  *
  * Usage: cat ./examples/lookup-environment-variable.plz | ./please --variable=PATH
  */
@runtime { context =>
  :context.arguments.lookup(variable) match {
    none: {}
    some: :context.environment.lookup >> :match({
      none: {}
      some: :identity
    })
  }
}
